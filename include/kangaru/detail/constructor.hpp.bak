#ifndef KANGARU5_DETAIL_CONSTRUCOR_HPP
#define KANGARU5_DETAIL_CONSTRUCOR_HPP

#include "concepts.hpp"
#include "utility.hpp"
#include "deducer.hpp"

#include "define.hpp"

namespace kangaru {
	namespace detail::constructor {
		template<unqualified_object Type>
		struct call_constructor_t {
		private:
			static constexpr auto call(int, auto&&... args)
				noexcept(noexcept(Type(KANGARU5_FWD(args)...)))
				-> decltype(Type(KANGARU5_FWD(args)...)) {
					return Type(KANGARU5_FWD(args)...);
				}
			
			static constexpr auto call(void*, auto&&... args)
				noexcept(noexcept(Type{KANGARU5_FWD(args)...}))
				-> decltype(Type{KANGARU5_FWD(args)...}) {
					return Type{KANGARU5_FWD(args)...};
				}
			
		public:
			constexpr auto operator()(auto&&... args) const noexcept(noexcept(call(0, KANGARU5_FWD(args)...))) -> decltype(call(0, KANGARU5_FWD(args)...)) {
				return call(0, KANGARU5_FWD(args)...);
			}
		};
		
		template<unqualified_object Type>
		struct call_deducing_constructor_t {
			template<typename From = Type>
			constexpr auto operator()(Type&& from) noexcept(noexcept(Type(KANGARU5_FWD(from)))) -> Type
				requires(
					not kangaru::deducer<std::remove_cvref_t<From>> and std::convertible_to<From&&, Type>
				)
			{
				// Here we don't use constructor_syntax_dispatch since we always only want a copy/move or a conversion
				return Type(KANGARU5_FWD(from));
			}
			
			constexpr auto operator()(auto arg1, auto&&... args)
				noexcept(noexcept(call_constructor_t<Type>{}(KANGARU5_FWD(arg1), KANGARU5_FWD(args)...)))
				-> Type
				requires(
					    not kangaru::deducer<std::remove_cvref_t<decltype(arg1)>>
					and constructor_callable<
						Type,
						decltype(arg1),
						decltype(args)...
					>
				)
			{
				return call_constructor_t<Type>{}(KANGARU5_FWD(arg1), KANGARU5_FWD(args)...);
			}
			
			constexpr auto operator()(kangaru::deducer auto deduce, auto&&... args)
				noexcept(noexcept(
					call_constructor_t<Type>{}(KANGARU5_NO_ADL(exclude_special_constructors_for<Type>)(deduce), KANGARU5_FWD(args)...)
				))
				-> Type
				requires constructor_callable<
					Type,
					exclude_special_constructors_deducer<Type, decltype(deduce)>,
					decltype(args)...
				>
			{
				return call_constructor_t<Type>{}(KANGARU5_NO_ADL(exclude_special_constructors_for<Type>)(deduce), KANGARU5_FWD(args)...);
			}
			
			// Since std::default_initializable<Type> would be invalid, promote Type to immidiate constext T
			template<typename T = Type>
			constexpr auto operator()() -> Type requires std::default_initializable<T> {
				return call_constructor_t<Type>{}();
			}
		};
	}
	
	template<unqualified_object Type>
	inline constexpr auto constructor() noexcept {
		using constructor_t = detail::constructor::call_constructor_t<Type>;
		return [](auto&&... args) requires(requires(constructor_t c){ { c(KANGARU5_FWD(args)...) } -> std::same_as<Type>; }) {
			return constructor_t{}(KANGARU5_FWD(args)...);
		};
	}
	
	template<unqualified_object Type>
	inline constexpr auto deducing_constructor_function() noexcept {
		return detail::constructor::call_deducing_constructor_t<Type>{};
	}
	
	template<unqualified_object Type>
	using deducing_constructor_function_t = decltype(deducing_constructor_function<Type>());

	template<typename Type, typename... Args>
	concept deducing_constructor_callable = callable<deducing_constructor_function_t<Type>, Args...>;
	
	template<unqualified_object Type, typename... Args> requires deducing_constructor_callable<Type, Args...>
	inline constexpr auto deducing_constructor(Args&&... args) -> Type {
		return deducing_constructor_function<Type>()(KANGARU5_FWD(args)...);
	}
}

#include "undef.hpp"

#endif // KANGARU5_DETAIL_CONSTRUCOR_HPP
